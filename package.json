{
  "name": "spinernet",
  "version": "1.0.0",
  "description": "SpinerNET - Advanced VPN Client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "build:all": "electron-builder --win --mac --linux"
  },
  "keywords": ["vpn", "proxy", "v2ray", "xray"],
  "author": "SpinerNET",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "node-fetch": "^3.3.2"
  },
  "build": {
    "appId": "com.spinernet.vpn",
    "productName": "SpinerNET",
    "icon": "renderer/assets/icon.ico",
    "asar": true,
    "asarUnpack": [
      "bin/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "renderer/assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SpinerNET"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*",
      "bin/**/*"
    ]
  }
}
